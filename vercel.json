{
  "rewrites": [
    {
      "source": "/manifest.webmanifest",
      "destination": "/manifest.webmanifest"
    },
    {
      "source": "/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/pwa-icon.svg",
      "destination": "/pwa-icon.svg"
    },
    {
      "source": "/api/sync/(.*)",
      "destination": "/api/sync"
    },
    {
      "source": "/api/sync/",
      "destination": "/api/sync"
    },
    {
      "source": "/api/push/(.*)",
      "destination": "/api/push"
    },
    {
      "source": "/api/push/",
      "destination": "/api/push"
    }
  ]
}
