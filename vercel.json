{
  "rewrites": [
    {
      "source": "/api/sync/(.*)",
      "destination": "/api/sync"
    },
    {
      "source": "/api/sync/",
      "destination": "/api/sync"
    },
    {
      "source": "/api/push/(.*)",
      "destination": "/api/push"
    },
    {
      "source": "/api/push/",
      "destination": "/api/push"
    }
  ]
}
