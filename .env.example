# Gemini API Key for AI features
GEMINI_API_KEY=

# Redis connection for pushing scheduling and cloud sync (Upstash recommended)
REDIS_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Web Push VAPID Keys (Generate with 'npx web-push generate-vapid-keys')
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your-email@example.com
